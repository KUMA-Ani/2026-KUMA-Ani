---
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		
		<link rel="icon" type="image/png" href="/favicon.png" />
		
		<title>{title}</title>
	</head>
	<body>
		<slot /> </body>
</html>
