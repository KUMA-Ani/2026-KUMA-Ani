---
import siteData from '../../data/site.json';

export function getStaticPaths() {
  return siteData.years.map(y => ({ params: { year: y.id } }));
}

const { year } = Astro.params;
const yearData = siteData.years.find(y => y.id === year);
const tracks = yearData?.tracks ?? [];
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KUMA {year} 졸업 전시회</title>
  <style>
    body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #000; font-family: 'Pretendard', sans-serif; }

    .back { position: fixed; top: 20px; left: 24px; z-index: 10; color: rgba(255,255,255,0.4); text-decoration: none; font-size: 1.4rem; transition: color 0.2s; line-height: 1; }
    .back:hover { color: #fff; }

    .container { display: flex; width: 100%; height: 100vh; }

    .track-section { position: relative; flex: 1; display: flex; align-items: center; justify-content: center; text-decoration: none; overflow: hidden; transition: flex 0.7s cubic-bezier(0.25,1,0.5,1); }
    .track-section:not(:last-child) { border-right: 1px solid rgba(255,255,255,0.08); }
    .track-section:hover { flex: 1.6; }

    .track-bg { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform 0.7s cubic-bezier(0.25,1,0.5,1); }
    .track-section:hover .track-bg { transform: scale(1.04); }
    .track-overlay { position: absolute; inset: 0; }

    .track-content { position: relative; z-index: 2; text-align: center; color: #fff; padding: 20px; }
    .category-tag { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 4px; color: rgba(255,255,255,0.5); margin-bottom: 12px; display: block; }
    .track-title { font-size: clamp(2rem, 4vw, 4rem); margin: 0; font-weight: 900; line-height: 1.1; }
    .track-desc { font-size: 0.95rem; opacity: 0.5; margin-top: 12px; line-height: 1.6; max-width: 280px; margin-left: auto; margin-right: auto; }
    .track-enter { margin-top: 24px; display: inline-block; font-size: 0.78rem; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,0.4); opacity: 0; transform: translateY(6px); transition: opacity 0.3s, transform 0.3s; }
    .track-section:hover .track-enter { opacity: 1; transform: translateY(0); }

    /* 트랙 없을 때 */
    .empty { display: flex; align-items: center; justify-content: center; width: 100%; height: 100vh; color: rgba(255,255,255,0.3); font-size: 1.1rem; flex-direction: column; gap: 12px; }

    @media (max-width: 768px) {
      body, html { overflow-y: auto; height: auto; }
      .container { flex-direction: column; height: auto; min-height: 100vh; padding: 70px 20px 40px; gap: 16px; box-sizing: border-box; }
      .track-section { flex: none; width: 100%; height: 240px; border-radius: 20px; overflow: hidden; border: none !important; transition: transform 0.3s; }
      .track-section:hover { flex: none; transform: scale(1.02); }
      .track-title { font-size: 2rem; }
    }
  </style>
</head>
<body>
  <a href="/" class="back">←</a>

  {tracks.length === 0 ? (
    <div class="empty">
      <span>등록된 트랙이 없습니다</span>
      <span style="font-size:0.8rem;">site.json에 트랙을 추가해주세요</span>
    </div>
  ) : (
    <div class="container">
      {tracks.map(track => (
        <a href={`/${year}/track/${track.id}/`} class="track-section">
          {track.bgImage && <div class="track-bg" style={`background-image:url('${track.bgImage}')`}></div>}
          <div class="track-overlay" style={`background:linear-gradient(${track.bgColor ?? 'rgba(0,0,0,0.4)'}, rgba(0,0,0,0.75))`}></div>
          <div class="track-content">
            <span class="category-tag">{track.category}</span>
            <h2 class="track-title">{track.title}</h2>
            <p class="track-desc">{track.description}</p>
            <span class="track-enter">입장하기 →</span>
          </div>
        </a>
      ))}
    </div>
  )}
</body>
</html>
