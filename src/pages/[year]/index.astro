---
import { fetchSiteData } from '../../lib/fetchSheetData';

export async function getStaticPaths() {
  const { fetchSiteData } = await import('../../lib/fetchSheetData');
  const { years } = await fetchSiteData();
  return years.map(y => ({ params: { year: y.id } }));
}

const { year } = Astro.params;
const { years } = await fetchSiteData();
const yearData = years.find(y => y.id === year);
const tracks = yearData?.tracks ?? [];
const trackCount = yearData?.trackCount ?? tracks.length;
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KUMA {year} 졸업 전시회</title>
  <style>
    body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #000; font-family: 'Pretendard', sans-serif; }

    .back {
      position: fixed; top: 24px; left: 28px; z-index: 10;
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      font-size: 2.2rem;
      line-height: 1;
      transition: color 0.2s, transform 0.2s;
      font-weight: 300;
    }
    .back:hover { color: #fff; transform: translateX(-4px); }

    .container { display: flex; width: 100%; height: 100vh; }
    .track-section { position: relative; flex: 1; display: flex; align-items: center; justify-content: center; text-decoration: none; overflow: hidden; transition: flex 0.7s cubic-bezier(0.25,1,0.5,1); }
    .track-section:not(:last-child) { border-right: 1px solid rgba(255,255,255,0.06); }
    .track-section:hover { flex: 1.6; }
    .track-bg { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform 0.7s cubic-bezier(0.25,1,0.5,1); }
    .track-section:hover .track-bg { transform: scale(1.05); }
    .track-overlay { position: absolute; inset: 0; }
    .track-content { position: relative; z-index: 2; text-align: center; color: #fff; padding: 24px; }
    .category-tag { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 5px; color: rgba(255,255,255,0.65); margin-bottom: 14px; display: block; font-weight: 500; }
    .track-title { font-size: clamp(2.2rem, 4vw, 4.5rem); margin: 0; font-weight: 900; line-height: 1.1; text-shadow: 0 2px 20px rgba(0,0,0,0.5); }
    .track-desc { font-size: 1rem; color: rgba(255,255,255,0.65); margin-top: 14px; line-height: 1.6; max-width: 280px; margin-left: auto; margin-right: auto; font-weight: 400; }
    .track-enter { margin-top: 28px; display: inline-block; font-size: 0.78rem; letter-spacing: 4px; text-transform: uppercase; color: rgba(255,255,255,0.5); opacity: 0; transform: translateY(8px); transition: opacity 0.3s, transform 0.3s; font-weight: 500; }
    .track-section:hover .track-enter { opacity: 1; transform: translateY(0); }

    @media (max-width: 768px) {
      body, html { overflow-y: auto; height: auto; }
      .container { flex-direction: column; height: auto; min-height: 100vh; padding: 80px 20px 40px; gap: 16px; box-sizing: border-box; }
      .track-section { flex: none; width: 100%; height: 240px; border-radius: 20px; overflow: hidden; border: none !important; transition: transform 0.3s; }
      .track-section:hover { flex: none; transform: scale(1.02); }
      .track-title { font-size: 2.2rem; }
    }
  </style>
</head>
<body>
  <a href="/" class="back">←</a>

  {trackCount <= 1 && tracks.length === 1 ? (
    <script define:vars={{ year, trackId: tracks[0]?.id }}>
      window.location.replace(`/${year}/track/${trackId}/`);
    </script>
    <div style="display:flex;align-items:center;justify-content:center;height:100vh;color:rgba(255,255,255,0.3);">이동 중...</div>
  ) : (
    <div class="container">
      {tracks.map(track => (
        <a href={`/${year}/track/${track.id}/`} class="track-section">
          {track.bgImage && <div class="track-bg" style={`background-image:url('${track.bgImage}')`}></div>}
          <div class="track-overlay" style={`background:linear-gradient(${track.bgColor ?? 'rgba(0,0,0,0.5)'}, rgba(0,0,0,0.8))`}></div>
          <div class="track-content">
            <span class="category-tag">{track.category}</span>
            <h2 class="track-title">{track.title}</h2>
            <p class="track-desc">{track.description}</p>
            <span class="track-enter">입장하기 →</span>
          </div>
        </a>
      ))}
    </div>
  )}
</body>
</html>
