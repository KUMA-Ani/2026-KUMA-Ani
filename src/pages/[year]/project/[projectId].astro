---
import { fetchSiteData } from '../../../lib/fetchSheetData';

export async function getStaticPaths() {
  const { fetchSiteData } = await import('../../../lib/fetchSheetData');
  const { years } = await fetchSiteData();
  const paths: any[] = [];
  years.forEach(y =>
    y.tracks.forEach(t =>
      t.projects.forEach(p =>
        paths.push({
          params: { year: y.id, projectId: p.id },
          props: { project: p, trackId: t.id, trackTitle: t.title, trackCount: y.trackCount ?? y.tracks.length }
        })
      )
    )
  );
  return paths;
}

const { year } = Astro.params;
const { project, trackId, trackTitle, trackCount } = Astro.props;

function nl(text: string | undefined) {
  if (!text) return '';
  return text.replace(/,/g, '\n');
}
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{project?.title} - KUMA {year}</title>
  <style>
    body { background: #000; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding: 0; }
    .container { max-width: 1360px; margin: 0 auto; padding: 40px 40px 100px; }

    .back {
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      font-size: 2.4rem;
      display: inline-block;
      margin-bottom: 28px;
      transition: color 0.2s, transform 0.2s;
      line-height: 1;
      font-weight: 300;
    }
    .back:hover { color: #fff; transform: translateX(-4px); }

    .breadcrumb { font-size: 0.75rem; color: rgba(255,255,255,0.4); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; font-weight: 500; }
    .breadcrumb span { color: rgba(255,255,255,0.2); margin: 0 8px; }
    h1 { font-size: clamp(1.9rem, 3.5vw, 3rem); font-weight: 900; margin: 0 0 6px; letter-spacing: -0.5px; color: #fff; }
    .subtitle { color: rgba(255,255,255,0.55); font-size: 0.95rem; margin-bottom: 40px; font-weight: 500; }

    .layout { display: grid; grid-template-columns: 1.8fr 1fr; gap: 28px; margin-bottom: 60px; align-items: start; }

    .video-wrap iframe { width: 100%; aspect-ratio: 16/9; border-radius: 14px; border: 1px solid rgba(255,255,255,0.08); display: block; }
    .no-video { aspect-ratio: 16/9; background: #0d0d0d; border-radius: 14px; border: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.25); font-size: 0.9rem; }
    .download-btn { display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 16px; padding: 18px; background: #007bff; color: #fff; border-radius: 12px; text-decoration: none; font-weight: 700; font-size: 0.95rem; transition: background 0.2s, transform 0.2s; }
    .download-btn:hover { background: #0069d9; transform: translateY(-2px); }

    .info-col { display: flex; flex-direction: column; gap: 16px; }
    .card { background: #0d0d0d; border: 1px solid rgba(255,255,255,0.08); border-radius: 18px; padding: 28px; }
    .card-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 4px; color: rgba(255,255,255,0.5); margin-bottom: 14px; display: flex; align-items: center; gap: 10px; font-weight: 600; }
    .card-label::before { content: ''; display: inline-block; width: 3px; height: 0.9rem; background: #007bff; border-radius: 2px; }
    .description { line-height: 1.9; color: rgba(255,255,255,0.8); font-size: 0.95rem; word-break: keep-all; white-space: pre-line; font-weight: 400; }

    .members-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 8px; }
    .member { background: #131313; border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 12px 8px; text-align: center; }
    .member-role { font-size: 0.68rem; color: rgba(255,255,255,0.45); display: block; margin-bottom: 4px; font-weight: 500; }
    .member-name { font-size: 0.92rem; font-weight: 700; color: #fff; display: block; }

    .gallery { border-top: 1px solid rgba(255,255,255,0.06); padding-top: 48px; }
    .gallery-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 4px; color: rgba(255,255,255,0.5); margin-bottom: 20px; display: flex; align-items: center; gap: 10px; font-weight: 600; }
    .gallery-label::before { content: ''; display: inline-block; width: 3px; height: 0.9rem; background: #007bff; border-radius: 2px; }

    .screenshots {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    /* 정사각형에 가까운 이미지 — 2열 유지 */
    .screenshot-item.square { grid-column: span 1; }

    /* 가로로 긴 이미지 — 1열 전체 */
    .screenshot-item.wide { grid-column: span 2; }

    /* 비율 감지 전 기본값 — 일단 전체 너비 */
    .screenshot-item { grid-column: span 2; }

    .screenshot-item img {
      width: 100%; display: block;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.06);
    }

    @media (max-width: 1024px) { .layout { grid-template-columns: 1fr; } }
    @media (max-width: 768px) {
      .container { padding: 24px 18px env(safe-area-inset-bottom, 100px); padding-bottom: max(100px, env(safe-area-inset-bottom, 0px) + 60px); }
      h1 { font-size: 1.8rem; }
      /* 모바일: 스크린샷 항상 1열 */
      .screenshots { grid-template-columns: 1fr; }
      .screenshot-item,
      .screenshot-item.square,
      .screenshot-item.wide { grid-column: span 1; }
    }
  </style>
</head>
<body>
  <div class="container">
    <a href={`/${year}/track/${trackId}/`} class="back">←</a>

    <p class="breadcrumb">
      {year}<span>/</span>{trackTitle}<span>/</span>{project?.type === 'team' ? 'Team' : 'Individual'}
    </p>
    <h1>{project?.title}</h1>
    <p class="subtitle">{project?.team}</p>

    <div class="layout">
      <div class="video-wrap">
        {project?.youtubeId
          ? <iframe src={`https://www.youtube.com/embed/${project.youtubeId}`} frameborder="0" allowfullscreen></iframe>
          : <div class="no-video">영상 없음</div>
        }
        {project?.downloadUrl && project.downloadUrl.trim() !== '' && (
          <a href={project.downloadUrl} class="download-btn" target="_blank" rel="noopener">
            ⬇ 다운로드
          </a>
        )}
      </div>

      <div class="info-col">
        <div class="card">
          <p class="card-label">작품 개요</p>
          <p class="description">{nl(project?.description) || '설명이 없습니다.'}</p>
        </div>

        {project?.members && project.members.length > 0 && (
          <div class="card">
            <p class="card-label">제작진</p>
            <div class="members-grid">
              {project.members.map((m: any) => (
                <div class="member">
                  <span class="member-role">{m.role}</span>
                  <span class="member-name">{m.name}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    {project?.screenshots && project.screenshots.length > 0 && (
      <div class="gallery">
        <p class="gallery-label">스크린샷</p>
        <div class="screenshots" id="screenshots">
          {project.screenshots.map((src: string, i: number) => (
            <div class="screenshot-item" data-index={i}>
              <img src={src} alt={`Screenshot ${i + 1}`} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    )}

  <script>
    function applyRatio(img) {
      const ratio = img.naturalWidth / img.naturalHeight;
      const item = img.closest('.screenshot-item');
      if (!item) return;
      // 1.2 미만 = 정사각형에 가까움 → 2열
      if (ratio < 1.2) {
        item.classList.add('square');
      } else {
        item.classList.add('wide');
      }
    }

    function initGallery() {
      const imgs = document.querySelectorAll('.screenshot-item img');
      imgs.forEach((img) => {
        if (img.complete && img.naturalWidth > 0) {
          applyRatio(img);
        } else {
          img.addEventListener('load', () => applyRatio(img));
          img.addEventListener('error', () => {
            img.closest('.screenshot-item')?.classList.add('wide');
          });
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGallery);
    } else {
      initGallery();
    }
  </script>
  </div>
</body>
</html>
