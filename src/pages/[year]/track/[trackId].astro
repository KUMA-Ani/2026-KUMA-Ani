---
import siteData from '../../../data/site.json';

export function getStaticPaths() {
  const paths = [];
  siteData.years.forEach(y =>
    y.tracks.forEach(t =>
      paths.push({ params: { year: y.id, trackId: t.id } })
    )
  );
  return paths;
}

const { year, trackId } = Astro.params;
const yearData = siteData.years.find(y => y.id === year);
const track = yearData?.tracks.find(t => t.id === trackId);
const teamProjects = track?.projects.filter(p => p.type === 'team') ?? [];
const indivProjects = track?.projects.filter(p => p.type === 'individual') ?? [];
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{track?.title ?? trackId} - KUMA {year}</title>
  <style>
    body { background: #080808; color: #eee; font-family: 'Pretendard', sans-serif; margin: 0; padding: 48px 48px 80px; }
    .back { color: rgba(255,255,255,0.35); text-decoration: none; font-size: 1.3rem; display: inline-block; margin-bottom: 28px; transition: color 0.2s; }
    .back:hover { color: #fff; }
    .page-title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; margin: 0 0 6px; letter-spacing: -1px; }
    .page-sub { color: #444; font-size: 0.85rem; margin-bottom: 56px; letter-spacing: 2px; text-transform: uppercase; }

    .section-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 4px; color: #444; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1px solid #111; }
    .section + .section { margin-top: 56px; }

    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 0; }

    .card { background: #101010; border: 1px solid #1a1a1a; border-radius: 14px; overflow: hidden; text-decoration: none; color: #fff; display: block; transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s; }
    .card:hover { border-color: #333; transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0,0,0,0.5); }
    .thumb { width: 100%; aspect-ratio: 16/9; background: #1a1a1a; background-size: cover; background-position: center; }
    .card-body { padding: 16px 18px; }
    .card-title { font-size: 1rem; font-weight: 700; margin: 0 0 4px; }
    .card-team { font-size: 0.8rem; color: #555; }

    @media (max-width: 768px) { body { padding: 32px 20px 60px; } .grid { grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; } }
  </style>
</head>
<body>
  <a href={`/${year}/`} class="back">← 트랙 선택</a>
  <h1 class="page-title">{track?.title ?? trackId}</h1>
  <p class="page-sub">{year} · {track?.category ?? ''}</p>

  {teamProjects.length > 0 && (
    <div class="section">
      <p class="section-label">Team Projects</p>
      <div class="grid">
        {teamProjects.map(p => (
          <a href={`/${year}/project/${p.id}/`} class="card">
            <div class="thumb" style={`background-image:url('${p.thumbnail || ''}')`}></div>
            <div class="card-body">
              <p class="card-title">{p.title}</p>
              <p class="card-team">{p.team}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {indivProjects.length > 0 && (
    <div class="section">
      <p class="section-label">Individual Projects</p>
      <div class="grid">
        {indivProjects.map(p => (
          <a href={`/${year}/project/${p.id}/`} class="card">
            <div class="thumb" style={`background-image:url('${p.thumbnail || ''}')`}></div>
            <div class="card-body">
              <p class="card-title">{p.title}</p>
              <p class="card-team">{p.team}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {teamProjects.length === 0 && indivProjects.length === 0 && (
    <p style="color:#333;margin-top:40px;">등록된 작품이 없습니다.</p>
  )}
</body>
</html>
