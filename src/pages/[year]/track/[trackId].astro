---
export async function getStaticPaths() {
  const siteData = await import('../../../data/site.json');
  const paths = [];
  siteData.years.forEach(y => {
    y.tracks.forEach(t => {
      paths.push({ params: { year: y.id, trackId: t.id } });
    });
  });
  return paths;
}
const { year, trackId } = Astro.params;
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KUMA {year} - 트랙</title>
  <style>
    body { background: #0b0b0b; color: #eee; font-family: 'Pretendard', sans-serif; padding: 50px 50px 80px; }
    .back { color: #555; text-decoration: none; margin-bottom: 20px; display: inline-block; font-size: 1.5rem; transition: color 0.2s; }
    .back:hover { color: #fff; }
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 50px; flex-wrap: wrap; gap: 16px; }
    h1 { font-size: 3rem; margin: 0; font-weight: 800; letter-spacing: -1px; }
    h2.section-title { font-size: 1.3rem; color: #007bff; margin-top: 60px; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 2px; display: flex; align-items: center; gap: 12px; }

    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }

    /* 작품 카드 */
    .project-card { position: relative; background: #161616; border-radius: 15px; overflow: hidden; text-decoration: none; color: white; transition: 0.3s; border: 1px solid #222; display: block; }
    .project-card:hover { transform: translateY(-8px); border-color: #007bff; box-shadow: 0 10px 30px rgba(0,123,255,0.2); }
    .thumb { width: 100%; aspect-ratio: 16/9; background-size: cover; background-position: center; background-color: #2a2a2a; }
    .card-info { padding: 18px; }
    .card-info h3 { margin: 0; font-size: 1.1rem; }
    .card-info p { color: #888; font-size: 0.85rem; margin-top: 4px; }
    .card-type-badge { display: inline-block; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 2px; padding: 2px 8px; border-radius: 20px; background: rgba(0,123,255,0.15); color: #4da6ff; border: 1px solid rgba(0,123,255,0.2); margin-bottom: 8px; }

    /* 관리자: 카드 편집 버튼 */
    .card-edit-btn {
      display: none; position: absolute; top: 10px; right: 10px;
      background: rgba(255,193,7,0.9); border: none; border-radius: 8px;
      padding: 4px 10px; font-size: 0.7rem; color: #000; font-weight: 700; cursor: pointer; z-index: 5;
    }
    .admin-mode .card-edit-btn { display: block; }

    /* 관리자: 카드 삭제 버튼 */
    .card-del-btn {
      display: none; position: absolute; top: 10px; left: 10px;
      background: rgba(220,53,69,0.9); border: none; border-radius: 8px;
      padding: 4px 10px; font-size: 0.7rem; color: #fff; font-weight: 700; cursor: pointer; z-index: 5;
    }
    .admin-mode .card-del-btn { display: block; }

    /* + 작품 추가 카드 */
    .add-project-card {
      display: none; background: transparent; border: 2px dashed rgba(255,255,255,0.15);
      border-radius: 15px; aspect-ratio: unset; min-height: 160px;
      align-items: center; justify-content: center; flex-direction: column;
      gap: 10px; color: rgba(255,255,255,0.3); cursor: pointer; transition: all 0.3s; font-size: 0.85rem;
    }
    .add-project-card:hover { border-color: rgba(255,255,255,0.4); color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.02); }
    .admin-mode .add-project-card { display: flex; }
    .add-project-card .plus { font-size: 2.5rem; line-height: 1; }

    @media (max-width: 768px) { body { padding: 30px 20px 80px; } h1 { font-size: 2rem; } }
  </style>
</head>
<body>
  <a href="javascript:history.back()" class="back">⬅</a>
  <div class="page-header">
    <h1 id="track-title">트랙</h1>
  </div>

  <div id="content"></div>

  <script type="module" define:vars={{ year, trackId }}>
    import { isAdmin, injectAdminBar, getData, saveData, showEditModal } from '/js/admin.js';

    let siteData, yearData, trackData, yi, ti;

    async function init() {
      siteData = await getData();
      yi = siteData.years.findIndex(y => y.id === year);
      yearData = siteData.years[yi];
      ti = yearData.tracks.findIndex(t => t.id === trackId);
      trackData = yearData.tracks[ti];
      document.getElementById('track-title').textContent = trackData?.title || trackId;
      render();
      if (isAdmin()) { document.body.classList.add('admin-mode'); injectAdminBar(); }
    }

    function render() {
      const content = document.getElementById('content');
      content.innerHTML = '';
      if (!trackData) return;

      const teamProjects = trackData.projects.filter(p => p.type === 'team');
      const indivProjects = trackData.projects.filter(p => p.type === 'individual');

      if (teamProjects.length > 0 || isAdmin()) {
        const h2 = document.createElement('h2');
        h2.className = 'section-title';
        h2.textContent = 'Team Projects';
        content.appendChild(h2);
        const grid = document.createElement('div');
        grid.className = 'grid';
        teamProjects.forEach(p => grid.appendChild(makeCard(p)));
        grid.appendChild(makeAddCard('team'));
        content.appendChild(grid);
      }

      if (indivProjects.length > 0 || isAdmin()) {
        const h2 = document.createElement('h2');
        h2.className = 'section-title';
        h2.textContent = 'Individual Projects';
        content.appendChild(h2);
        const grid = document.createElement('div');
        grid.className = 'grid';
        indivProjects.forEach(p => grid.appendChild(makeCard(p)));
        grid.appendChild(makeAddCard('individual'));
        content.appendChild(grid);
      }

      if (teamProjects.length === 0 && indivProjects.length === 0 && !isAdmin()) {
        const empty = document.createElement('p');
        empty.style.color = 'rgba(255,255,255,0.3)';
        empty.style.marginTop = '40px';
        empty.textContent = '등록된 작품이 없습니다.';
        content.appendChild(empty);
      }
    }

    function makeCard(p) {
      const wrap = document.createElement('div');
      wrap.style.position = 'relative';

      const card = document.createElement('a');
      card.className = 'project-card';
      card.href = `/${year}/project/${p.id}/`;
      card.innerHTML = `
        <div class="thumb" style="background-image:url('${p.thumbnail || ''}')"></div>
        <div class="card-info">
          <span class="card-type-badge">${p.type === 'team' ? 'TEAM' : 'INDIVIDUAL'}</span>
          <h3>${p.title}</h3>
          <p>${p.team || ''}</p>
        </div>
      `;

      const editBtn = document.createElement('button');
      editBtn.className = 'card-edit-btn';
      editBtn.textContent = '✏️ 편집';
      editBtn.addEventListener('click', e => { e.preventDefault(); e.stopPropagation(); editProject(p.id); });

      const delBtn = document.createElement('button');
      delBtn.className = 'card-del-btn';
      delBtn.textContent = '🗑';
      delBtn.addEventListener('click', e => { e.preventDefault(); e.stopPropagation(); deleteProject(p.id); });

      wrap.appendChild(card);
      wrap.appendChild(editBtn);
      wrap.appendChild(delBtn);
      return wrap;
    }

    function makeAddCard(type) {
      const div = document.createElement('div');
      div.className = 'add-project-card';
      div.innerHTML = `<span class="plus">+</span><span>${type === 'team' ? '팀' : '개인'} 작품 추가</span>`;
      div.addEventListener('click', () => addProject(type));
      return div;
    }

    function editProject(pid) {
      const p = trackData.projects.find(x => x.id === pid);
      showEditModal({
        title: `"${p.title}" 작품 편집`,
        fields: [
          { key: 'title', label: '작품 제목', value: p.title },
          { key: 'team', label: '팀명 / 작가명', value: p.team || '' },
          { key: 'description', label: '작품 설명', type: 'textarea', value: p.description || '' },
          { key: 'youtubeId', label: '유튜브 영상 ID (예: dQw4w9WgXcQ)', value: p.youtubeId || '' },
          { key: 'thumbnail', label: '썸네일 이미지 URL', value: p.thumbnail || '' },
          { key: 'downloadUrl', label: '다운로드 링크 (게임만)', value: p.downloadUrl || '' },
        ],
        onSave(vals) {
          const pi = trackData.projects.findIndex(x => x.id === pid);
          Object.assign(siteData.years[yi].tracks[ti].projects[pi], vals);
          saveData(siteData);
          trackData = siteData.years[yi].tracks[ti];
          render();
        }
      });
    }

    function deleteProject(pid) {
      const p = trackData.projects.find(x => x.id === pid);
      if (!confirm(`"${p.title}" 작품을 삭제하시겠습니까?`)) return;
      siteData.years[yi].tracks[ti].projects = trackData.projects.filter(x => x.id !== pid);
      saveData(siteData);
      trackData = siteData.years[yi].tracks[ti];
      render();
    }

    function addProject(type) {
      showEditModal({
        title: `${type === 'team' ? '팀' : '개인'} 작품 추가`,
        fields: [
          { key: 'title', label: '작품 제목', value: '' },
          { key: 'team', label: '팀명 / 작가명', value: '' },
          { key: 'description', label: '작품 설명', type: 'textarea', value: '' },
          { key: 'youtubeId', label: '유튜브 영상 ID', value: '' },
          { key: 'thumbnail', label: '썸네일 이미지 URL', value: '' },
          { key: 'downloadUrl', label: '다운로드 링크 (게임만)', value: '' },
        ],
        onSave(vals) {
          if (!vals.title) return alert('작품 제목을 입력해주세요.');
          const newId = `${trackId.toLowerCase().slice(0,2)}-${type.slice(0,1)}-${Date.now()}`;
          siteData.years[yi].tracks[ti].projects.push({
            id: newId, type, ...vals,
            members: [], screenshots: []
          });
          saveData(siteData);
          trackData = siteData.years[yi].tracks[ti];
          render();
        }
      });
    }

    init();
  </script>
</body>
</html>
