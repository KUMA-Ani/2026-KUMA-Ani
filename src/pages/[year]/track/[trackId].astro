---
import { fetchSiteData } from '../../../lib/fetchSheetData';

export async function getStaticPaths() {
  const { fetchSiteData } = await import('../../../lib/fetchSheetData');
  const { years } = await fetchSiteData();
  const paths: any[] = [];
  years.forEach(y => y.tracks.forEach(t => paths.push({ params: { year: y.id, trackId: t.id } })));
  return paths;
}

const { year, trackId } = Astro.params;
const { years } = await fetchSiteData();
const yearData = years.find(y => y.id === year);
const track = yearData?.tracks.find(t => t.id === trackId);
const teamProjects = track?.projects.filter(p => p.type === 'team') ?? [];
const indivProjects = track?.projects.filter(p => p.type === 'individual') ?? [];
const showTrackNav = (yearData?.trackCount ?? 1) > 1;
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{track?.title ?? trackId} - KUMA {year} | 한국영상대학교 게임애니메이션과</title>
  <meta name="description" content={`한국영상대학교 게임애니메이션과 ${year} 졸업 전시회 ${track?.title ?? ''} 작품 목록`} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={`${track?.title} | KUMA ${year}`} />
  <meta property="og:description" content={`한국영상대학교 게임애니메이션과 ${year} 졸업 전시회 ${track?.title ?? ''}`} />
  <meta property="og:locale" content="ko_KR" />
  <style>
    body { background: #080808; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding: 56px 52px 100px; }

    .back {
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      font-size: 2rem;
      display: inline-block;
      margin-bottom: 32px;
      transition: color 0.2s, transform 0.2s;
      line-height: 1;
      font-weight: 300;
    }
    .back:hover { color: #fff; transform: translateX(-4px); }

    .page-title { font-size: clamp(2.2rem, 4vw, 3.2rem); font-weight: 900; margin: 0 0 6px; letter-spacing: -1px; color: #fff; }
    .page-sub { color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-bottom: 60px; letter-spacing: 3px; text-transform: uppercase; font-weight: 500; }

    .section-label {
      font-size: 0.72rem; text-transform: uppercase; letter-spacing: 5px;
      color: rgba(255,255,255,0.5); font-weight: 600;
      margin-bottom: 18px; padding-bottom: 12px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .section + .section { margin-top: 60px; }

    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }

    .card {
      background: #111; border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px; overflow: hidden; text-decoration: none; color: #fff;
      display: block; transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    }
    .card:hover { border-color: rgba(255,255,255,0.2); transform: translateY(-6px); box-shadow: 0 20px 50px rgba(0,0,0,0.6); }
    .thumb { width: 100%; aspect-ratio: 16/9; background: #1a1a1a; background-size: cover; background-position: center; }
    .card-body { padding: 18px 20px; }
    .card-title { font-size: 1.05rem; font-weight: 700; margin: 0 0 5px; color: #fff; }
    .card-team { font-size: 0.82rem; color: rgba(255,255,255,0.55); font-weight: 500; }

    .empty { color: rgba(255,255,255,0.3); margin-top: 40px; font-size: 0.9rem; }

    @media (max-width: 768px) {
      body { padding: 36px 20px 80px; }
      .grid { grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; }
    }
  </style>
</head>
<body>
  <a href={showTrackNav ? `/${year}/` : '/'} class="back">←</a>

  <h1 class="page-title">{track?.title ?? trackId}</h1>
  <p class="page-sub">{year} · {track?.category ?? ''}</p>

  {teamProjects.length > 0 && (
    <div class="section">
      <p class="section-label">Team Projects</p>
      <div class="grid">
        {teamProjects.map(p => (
          <a href={`/${year}/project/${p.id}/`} class="card">
            <div class="thumb" style={p.thumbnail ? `background-image:url('${p.thumbnail}')` : ''}></div>
            <div class="card-body">
              <p class="card-title">{p.title}</p>
              <p class="card-team">{p.team}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {indivProjects.length > 0 && (
    <div class="section">
      <p class="section-label">Individual Projects</p>
      <div class="grid">
        {indivProjects.map(p => (
          <a href={`/${year}/project/${p.id}/`} class="card">
            <div class="thumb" style={p.thumbnail ? `background-image:url('${p.thumbnail}')` : ''}></div>
            <div class="card-body">
              <p class="card-title">{p.title}</p>
              <p class="card-team">{p.team}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {teamProjects.length === 0 && indivProjects.length === 0 && (
    <p class="empty">등록된 작품이 없습니다.</p>
  )}
</body>
</html>
