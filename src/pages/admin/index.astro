---
// 관리자 전용 페이지 - 로그인 + 대시보드
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KUMA 관리자</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #060606; color: #eee; font-family: 'Pretendard', 'Inter', sans-serif; min-height: 100vh; }

    /* ── 로그인 화면 ── */
    #login-screen {
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh; padding: 20px;
      background: radial-gradient(ellipse at 50% 40%, rgba(0,80,200,0.1) 0%, transparent 60%), #060606;
    }
    .login-box {
      background: #0f0f0f; border: 1px solid #222; border-radius: 24px;
      padding: 48px 44px; width: 100%; max-width: 400px; text-align: center;
    }
    .login-logo { font-size: 2.5rem; font-weight: 900; letter-spacing: -1px; color: #fff; margin-bottom: 4px; }
    .login-sub { font-size: 0.8rem; color: rgba(255,255,255,0.3); letter-spacing: 4px; text-transform: uppercase; margin-bottom: 36px; }
    .login-field { text-align: left; margin-bottom: 14px; }
    .login-field label { display: block; font-size: 0.78rem; color: #666; margin-bottom: 6px; }
    .login-field input {
      width: 100%; padding: 12px 16px; background: #1a1a1a; border: 1px solid #2a2a2a;
      border-radius: 10px; color: #fff; font-size: 0.95rem; outline: none; transition: border-color 0.2s;
    }
    .login-field input:focus { border-color: #444; }
    .login-btn {
      width: 100%; padding: 13px; margin-top: 8px; background: #ffc107; border: none;
      border-radius: 10px; color: #000; font-weight: 800; font-size: 1rem; cursor: pointer; transition: 0.2s;
    }
    .login-btn:hover { background: #ffca28; }
    .login-err { color: #ff5555; font-size: 0.82rem; margin-top: 10px; display: none; }

    /* ── 대시보드 ── */
    #dashboard { display: none; }

    .top-bar {
      position: sticky; top: 0; z-index: 100;
      background: rgba(6,6,6,0.97); backdrop-filter: blur(10px);
      border-bottom: 1px solid #1a1a1a;
      padding: 0 32px; height: 60px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .top-bar-left { display: flex; align-items: center; gap: 16px; }
    .top-bar-logo { font-size: 1.1rem; font-weight: 900; color: #fff; }
    .admin-badge { font-size: 0.7rem; background: #ffc107; color: #000; padding: 3px 8px; border-radius: 6px; font-weight: 700; }
    .top-bar-actions { display: flex; gap: 10px; }
    .tb-btn { padding: 7px 16px; border-radius: 8px; border: 1px solid #2a2a2a; background: #111; color: #aaa; font-size: 0.78rem; cursor: pointer; transition: 0.2s; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
    .tb-btn:hover { background: #1a1a1a; color: #fff; }
    .tb-btn.primary { background: #007bff; border-color: #007bff; color: #fff; }
    .tb-btn.primary:hover { background: #0066d6; }
    .tb-btn.danger { border-color: #dc3545; color: #ff6b6b; }
    .tb-btn.danger:hover { background: rgba(220,53,69,0.1); }

    .dashboard-body { max-width: 1200px; margin: 0 auto; padding: 40px 32px 80px; }

    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .section-header h2 { font-size: 1.1rem; font-weight: 700; color: #fff; display: flex; align-items: center; gap: 10px; }
    .section-header h2::before { content: ''; display: inline-block; width: 4px; height: 1rem; background: #ffc107; border-radius: 2px; }
    .add-btn { padding: 7px 16px; background: rgba(0,123,255,0.15); border: 1px solid rgba(0,123,255,0.3); border-radius: 8px; color: #4da6ff; font-size: 0.8rem; cursor: pointer; transition: 0.2s; }
    .add-btn:hover { background: rgba(0,123,255,0.25); }

    /* 연도 섹션 */
    .year-section { margin-bottom: 48px; background: #0d0d0d; border: 1px solid #1a1a1a; border-radius: 20px; overflow: hidden; }
    .year-section-header { padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #1a1a1a; }
    .year-section-title { font-size: 1.4rem; font-weight: 800; display: flex; align-items: center; gap: 12px; }
    .year-status { font-size: 0.65rem; padding: 3px 8px; border-radius: 20px; }
    .year-status.open { background: rgba(0,200,100,0.1); color: #00c864; border: 1px solid rgba(0,200,100,0.2); }
    .year-status.closed { background: rgba(255,255,255,0.05); color: #666; border: 1px solid #222; }
    .year-actions { display: flex; gap: 8px; }

    .tracks-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1px; background: #1a1a1a; }
    .track-card { background: #0d0d0d; padding: 20px 24px; transition: background 0.2s; }
    .track-card:hover { background: #111; }
    .track-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .track-name { font-size: 1rem; font-weight: 700; color: #fff; }
    .track-count { font-size: 0.75rem; color: #555; }
    .track-desc { font-size: 0.8rem; color: #555; line-height: 1.5; margin-bottom: 14px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
    .track-card-actions { display: flex; gap: 8px; }
    .small-btn { padding: 5px 12px; border-radius: 7px; font-size: 0.72rem; cursor: pointer; border: 1px solid #2a2a2a; background: #111; color: #888; transition: 0.2s; text-decoration: none; }
    .small-btn:hover { background: #1a1a1a; color: #fff; }
    .small-btn.blue { border-color: rgba(0,123,255,0.3); color: #4da6ff; background: rgba(0,123,255,0.08); }
    .small-btn.blue:hover { background: rgba(0,123,255,0.15); }
    .small-btn.red { border-color: rgba(220,53,69,0.3); color: #ff6b6b; background: rgba(220,53,69,0.05); }
    .small-btn.red:hover { background: rgba(220,53,69,0.1); }

    .add-track-card { background: #0a0a0a; padding: 20px 24px; display: flex; align-items: center; justify-content: center; cursor: pointer; border: 2px dashed transparent; transition: 0.2s; }
    .add-track-card:hover { border-color: #333; background: #0f0f0f; }
    .add-track-card span { color: #333; font-size: 0.85rem; transition: color 0.2s; }
    .add-track-card:hover span { color: #666; }

    /* 내보내기 안내 */
    .export-guide { background: rgba(255,193,7,0.05); border: 1px solid rgba(255,193,7,0.15); border-radius: 16px; padding: 24px 28px; margin-top: 40px; }
    .export-guide h3 { color: #ffc107; font-size: 0.95rem; margin-bottom: 10px; }
    .export-guide ol { color: #888; font-size: 0.85rem; line-height: 2; padding-left: 18px; }
    .export-guide ol li span { color: #ccc; }

    /* 반응형 */
    @media (max-width: 600px) { .dashboard-body { padding: 24px 16px 60px; } .top-bar { padding: 0 16px; } }
  </style>
</head>
<body>

  <!-- 로그인 화면 -->
  <div id="login-screen">
    <div class="login-box">
      <div class="login-logo">KUMA</div>
      <div class="login-sub">Admin Panel</div>
      <div class="login-field">
        <label>아이디</label>
        <input type="text" id="login-id" placeholder="아이디 입력" autocomplete="username" />
      </div>
      <div class="login-field">
        <label>비밀번호</label>
        <input type="password" id="login-pw" placeholder="비밀번호 입력" autocomplete="current-password" />
      </div>
      <p class="login-err" id="login-err">아이디 또는 비밀번호가 올바르지 않습니다.</p>
      <button class="login-btn" id="login-btn">로그인</button>
    </div>
  </div>

  <!-- 대시보드 -->
  <div id="dashboard">
    <div class="top-bar">
      <div class="top-bar-left">
        <span class="top-bar-logo">KUMA</span>
        <span class="admin-badge">관리자</span>
        <a href="/" class="tb-btn" target="_blank">🌐 사이트 보기</a>
      </div>
      <div class="top-bar-actions">
        <button class="tb-btn primary" id="tb-export">⬇ JSON 내보내기</button>
        <button class="tb-btn danger" id="tb-logout">로그아웃</button>
      </div>
    </div>

    <div class="dashboard-body">
      <div class="section-header">
        <h2>연도 관리</h2>
        <button class="add-btn" id="add-year-btn">+ 연도 추가</button>
      </div>

      <div id="years-list"></div>

      <div class="export-guide">
        <h3>📌 변경사항 반영 방법</h3>
        <ol>
          <li><span>위 "JSON 내보내기" 버튼</span>을 눌러 <code>site.json</code> 다운로드</li>
          <li>다운로드한 파일을 프로젝트의 <span><code>public/data/site.json</code></span> 과 <span><code>src/data/site.json</code></span> 두 곳에 덮어쓰기</li>
          <li>GitHub에 push → Vercel 자동 배포</li>
        </ol>
      </div>
    </div>
  </div>

  <script type="module">
    import { isAdmin, login, logout, getData, saveData, exportJSON, showEditModal } from '/js/admin.js';

    let siteData;

    // ── 로그인 처리 ────────────────────────────────────────
    function tryLogin() {
      const id = document.getElementById('login-id').value;
      const pw = document.getElementById('login-pw').value;
      if (login(id, pw)) {
        showDashboard();
      } else {
        document.getElementById('login-err').style.display = 'block';
      }
    }

    document.getElementById('login-btn').onclick = tryLogin;
    document.getElementById('login-pw').onkeydown = e => { if (e.key === 'Enter') tryLogin(); };
    document.getElementById('login-id').onkeydown = e => { if (e.key === 'Enter') document.getElementById('login-pw').focus(); };

    // ── 대시보드 표시 ──────────────────────────────────────
    async function showDashboard() {
      document.getElementById('login-screen').style.display = 'none';
      document.getElementById('dashboard').style.display = 'block';
      siteData = await getData();
      renderYears();

      document.getElementById('tb-export').onclick = exportJSON;
      document.getElementById('tb-logout').onclick = () => { logout(); };
      document.getElementById('add-year-btn').onclick = addYear;
    }

    // ── 연도 목록 렌더 ────────────────────────────────────
    function renderYears() {
      const list = document.getElementById('years-list');
      list.innerHTML = '';
      siteData.years.forEach((year, yi) => {
        const section = document.createElement('div');
        section.className = 'year-section';
        section.innerHTML = `
          <div class="year-section-header">
            <div class="year-section-title">
              ${year.label}
              <span class="year-status ${year.active ? 'open' : 'closed'}">${year.active ? 'OPEN' : '준비중'}</span>
            </div>
            <div class="year-actions">
              <button class="small-btn blue" data-action="edit-year" data-yi="${yi}">✏️ 연도 편집</button>
              <button class="small-btn" data-action="toggle-year" data-yi="${yi}">${year.active ? '비활성화' : '활성화'}</button>
              <button class="small-btn red" data-action="del-year" data-yi="${yi}">삭제</button>
            </div>
          </div>
          <div class="tracks-grid" id="tracks-${yi}"></div>
        `;
        list.appendChild(section);
        renderTracks(yi);
      });

      // 이벤트 위임
      list.querySelectorAll('[data-action]').forEach(btn => {
        btn.onclick = handleYearAction;
      });
    }

    function handleYearAction(e) {
      const { action, yi } = e.currentTarget.dataset;
      const yiNum = parseInt(yi);
      if (action === 'edit-year') editYear(yiNum);
      if (action === 'toggle-year') toggleYear(yiNum);
      if (action === 'del-year') deleteYear(yiNum);
    }

    // ── 트랙 렌더 ─────────────────────────────────────────
    function renderTracks(yi) {
      const grid = document.getElementById(`tracks-${yi}`);
      if (!grid) return;
      grid.innerHTML = '';
      const year = siteData.years[yi];

      year.tracks.forEach((track, ti) => {
        const card = document.createElement('div');
        card.className = 'track-card';
        const projCount = track.projects?.length || 0;
        card.innerHTML = `
          <div class="track-card-header">
            <span class="track-name">${track.title}</span>
            <span class="track-count">작품 ${projCount}개</span>
          </div>
          <p class="track-desc">${track.description || '설명 없음'}</p>
          <div class="track-card-actions">
            <a href="/${year.id}/track/${track.id}/" class="small-btn blue" target="_blank">작품 목록 →</a>
            <button class="small-btn" data-action="edit-track" data-yi="${yi}" data-ti="${ti}">✏️ 편집</button>
            <button class="small-btn red" data-action="del-track" data-yi="${yi}" data-ti="${ti}">삭제</button>
          </div>
        `;
        grid.appendChild(card);
      });

      // 트랙 추가 카드
      const addCard = document.createElement('div');
      addCard.className = 'add-track-card';
      addCard.innerHTML = '<span>+ 트랙 추가</span>';
      addCard.onclick = () => addTrack(yi);
      grid.appendChild(addCard);

      grid.querySelectorAll('[data-action]').forEach(btn => {
        btn.onclick = handleTrackAction;
      });
    }

    function handleTrackAction(e) {
      const { action, yi, ti } = e.currentTarget.dataset;
      if (action === 'edit-track') editTrack(parseInt(yi), parseInt(ti));
      if (action === 'del-track') deleteTrack(parseInt(yi), parseInt(ti));
    }

    // ── 연도 CRUD ─────────────────────────────────────────
    function editYear(yi) {
      const y = siteData.years[yi];
      showEditModal({
        title: `${y.label} 연도 편집`,
        fields: [
          { key: 'label', label: '연도 표시 텍스트', value: y.label },
          { key: 'thumbnail', label: '배경 이미지 URL', value: y.thumbnail || '' },
        ],
        onSave(v) {
          siteData.years[yi].label = v.label;
          siteData.years[yi].thumbnail = v.thumbnail;
          saveData(siteData); renderYears();
        }
      });
    }

    function toggleYear(yi) {
      siteData.years[yi].active = !siteData.years[yi].active;
      saveData(siteData); renderYears();
    }

    function deleteYear(yi) {
      const y = siteData.years[yi];
      if (!confirm(`"${y.label}" 연도를 삭제하시겠습니까?\n포함된 트랙과 작품이 모두 삭제됩니다.`)) return;
      siteData.years.splice(yi, 1);
      saveData(siteData); renderYears();
    }

    function addYear() {
      showEditModal({
        title: '새 연도 추가',
        fields: [
          { key: 'id', label: '연도 ID (예: 2027)', value: '' },
          { key: 'label', label: '표시 텍스트 (예: 2027)', value: '' },
          { key: 'thumbnail', label: '배경 이미지 URL (선택)', value: '' },
        ],
        onSave(v) {
          if (!v.id) return alert('연도 ID를 입력해주세요.');
          siteData.years.push({ id: v.id, label: v.label || v.id, active: true, thumbnail: v.thumbnail, tracks: [] });
          saveData(siteData); renderYears();
        }
      });
    }

    // ── 트랙 CRUD ─────────────────────────────────────────
    function editTrack(yi, ti) {
      const t = siteData.years[yi].tracks[ti];
      showEditModal({
        title: `"${t.title}" 트랙 편집`,
        fields: [
          { key: 'title', label: '트랙 이름', value: t.title },
          { key: 'category', label: '카테고리 태그', value: t.category || '' },
          { key: 'description', label: '설명', type: 'textarea', value: t.description || '' },
          { key: 'thumbnail', label: '카드 이미지 URL', value: t.thumbnail || '' },
          { key: 'bgImage', label: '배경 이미지 URL', value: t.bgImage || '' },
          { key: 'bgColor', label: '오버레이 색상 (예: rgba(0,123,255,0.3))', value: t.bgColor || '' },
        ],
        onSave(v) {
          Object.assign(siteData.years[yi].tracks[ti], v);
          saveData(siteData); renderTracks(yi);
        }
      });
    }

    function deleteTrack(yi, ti) {
      const t = siteData.years[yi].tracks[ti];
      if (!confirm(`"${t.title}" 트랙을 삭제하시겠습니까?`)) return;
      siteData.years[yi].tracks.splice(ti, 1);
      saveData(siteData); renderTracks(yi);
    }

    function addTrack(yi) {
      showEditModal({
        title: '새 트랙 추가',
        fields: [
          { key: 'id', label: '트랙 ID (영문, 예: Games)', value: '' },
          { key: 'title', label: '트랙 이름', value: '' },
          { key: 'category', label: '카테고리 태그', value: '' },
          { key: 'description', label: '설명', type: 'textarea', value: '' },
          { key: 'thumbnail', label: '카드 이미지 URL', value: '' },
          { key: 'bgImage', label: '배경 이미지 URL', value: '' },
          { key: 'bgColor', label: '오버레이 색상', value: 'rgba(0,123,255,0.3)' },
        ],
        onSave(v) {
          if (!v.id) return alert('트랙 ID를 입력해주세요.');
          siteData.years[yi].tracks.push({ ...v, projects: [] });
          saveData(siteData); renderTracks(yi);
        }
      });
    }

    // ── 초기화 ────────────────────────────────────────────
    if (isAdmin()) {
      showDashboard();
    } else {
      setTimeout(() => document.getElementById('login-id')?.focus(), 100);
    }
  </script>
</body>
</html>
