---
import projects from '../data/projects.json';

const tracks = projects.filter(p => p.category);
const gameTrack = tracks.find(t => t.id === 'Games');
const animationTrack = tracks.find(t => t.id === 'Animations');
---

<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KUMA 졸업 전시회 - 트랙 선택</title>
    <style>
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background-color: #000; font-family: 'Pretendard', sans-serif; }
        
        /* 기본 레이아웃: 가로 배치 */
        .split-container { display: flex; width: 100%; height: 100vh; flex-direction: row; }
        
        .track-section { position: relative; flex: 1; display: flex; align-items: center; justify-content: center; text-decoration: none; overflow: hidden; transition: flex 0.7s cubic-bezier(0.25, 1, 0.5, 1); }
        
        .game { background: linear-gradient(rgba(0, 123, 255, 0.3), rgba(0, 0, 0, 0.8)), url('https://images.unsplash.com/photo-1542751371-adc38448a05e?auto=format&fit=crop&w=1920&q=80'); background-size: cover; background-position: center; border-right: 1px solid rgba(255, 255, 255, 0.1); }
        .animation { background: linear-gradient(rgba(220, 53, 69, 0.3), rgba(0, 0, 0, 0.8)), url('https://images.unsplash.com/photo-1550745165-9bc0b252726f?auto=format&fit=crop&w=1920&q=80'); background-size: cover; background-position: center; }
        
        .track-section:hover { flex: 1.5; }
        .track-content { position: relative; z-index: 2; text-align: center; color: white; transition: transform 0.3s ease; }
        .category-tag { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 4px; color: rgba(255, 255, 255, 0.6); margin-bottom: 10px; display: block; }
        h2 { font-size: 4rem; margin: 0; font-weight: 900; }
        .description { font-size: 1.1rem; opacity: 0.7; margin-top: 15px; }

        /* ✨ 모바일 반응형 추가: 화면 너비가 768px 이하일 때 */
@media (max-width: 768px) {
            .split-container { 
                flex-direction: column;
                overflow: hidden; /* 스크롤바 때문에 생기는 틈 방지 */
            }
            .track-section { 
                width: 100%; 
                height: 50vh; 
                border-right: none;
                
                /* 1. 틈새 방지 핵심: 아래쪽 섹션과 아주 살짝 겹치게 설정 */
                margin-bottom: -1px; 
                
                /* 2. 경계선 설정 (필요 없다면 0px로 변경 가능) */
                border-bottom: 1px solid rgba(255, 255, 255, 0.05); 
                
                transition: height 0.7s ease;
            }

            /* 3. 아래쪽 섹션(애니메이션)의 그라데이션 시작점을 조정하여 경계를 더 자연스럽게 */
            .animation { 
                background: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(220, 53, 69, 0.2) 100%), 
                            url('https://images.unsplash.com/photo-1550745165-9bc0b252726f?auto=format&fit=crop&w=1920&q=80');
                background-size: cover;
                background-position: center;
            }

            .game {
                background: linear-gradient(to top, rgba(0, 0, 0, 1) 0%, rgba(0, 123, 255, 0.2) 100%), 
                            url('https://images.unsplash.com/photo-1542751371-adc38448a05e?auto=format&fit=crop&w=1920&q=80');
                background-size: cover;
                background-position: center;
            }

            h2 { font-size: 2.5rem; }
        }
    </style>
</head>
<body>
    <div class="split-container">
        <a href="/track/Games/" class="track-section game">
            <div class="track-content">
                <span class="category-tag">Game Track</span>
                <h2>{gameTrack?.title || "GAME"}</h2>
                <p class="description">인터랙티브한 미래를 설계하다</p>
            </div>
        </a>
        <a href="/track/Animations/" class="track-section animation">
            <div class="track-content">
                <span class="category-tag">Animation Track</span>
                <h2>{animationTrack?.title || "ANIMATION"}</h2>
                <p class="description">상상을 움직임으로 구현하다</p>
            </div>
        </a>
    </div>
</body>
</html>
