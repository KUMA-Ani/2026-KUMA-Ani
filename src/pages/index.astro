---
// 연도 선택 메인 페이지 - 일반 사용자용 (관리자 트리거 없음)
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KUMA 졸업 전시회</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body, html { width: 100%; height: 100%; background: #000; color: #fff; font-family: 'Pretendard', 'Inter', sans-serif; overflow: hidden; }
    .bg { position: fixed; inset: 0; background: radial-gradient(ellipse at 20% 50%, rgba(0,80,200,0.12) 0%, transparent 60%), radial-gradient(ellipse at 80% 50%, rgba(180,30,60,0.10) 0%, transparent 60%), #000; z-index: 0; }
    .grid-overlay { position: fixed; inset: 0; z-index: 0; background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 60px 60px; }
    .page { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; height: 100vh; gap: 60px; }
    .header { text-align: center; }
    .header .label { font-size: 0.8rem; letter-spacing: 6px; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 16px; }
    .header h1 { font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 900; letter-spacing: -2px; line-height: 1; background: linear-gradient(135deg, #fff 30%, rgba(255,255,255,0.4)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .header .sub { font-size: 1rem; color: rgba(255,255,255,0.3); margin-top: 12px; }
    .years-container { display: flex; gap: 20px; align-items: center; flex-wrap: wrap; justify-content: center; padding: 0 20px; }
    .year-card { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 220px; height: 280px; border-radius: 24px; text-decoration: none; color: white; overflow: hidden; transition: transform 0.4s cubic-bezier(0.25,1,0.5,1), box-shadow 0.4s ease; border: 1px solid rgba(255,255,255,0.15); background: linear-gradient(145deg, #111 0%, #0a0a0a 100%); box-shadow: 0 0 0 1px rgba(255,255,255,0.05), 0 30px 60px rgba(0,0,0,0.5); }
    .year-card::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(0,100,255,0.15) 0%, rgba(180,30,60,0.1) 100%); }
    .year-card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0.2; }
    .year-card:hover { transform: translateY(-8px) scale(1.02); box-shadow: 0 0 0 1px rgba(100,160,255,0.2), 0 40px 80px rgba(0,80,200,0.25); }
    .year-badge { position: absolute; top: 18px; right: 18px; font-size: 0.65rem; letter-spacing: 3px; text-transform: uppercase; padding: 4px 10px; border-radius: 20px; color: rgba(100,200,255,0.8); background: rgba(0,100,255,0.12); border: 1px solid rgba(0,100,255,0.2); z-index: 1; }
    .year-number { font-size: 4.5rem; font-weight: 900; letter-spacing: -4px; line-height: 1; position: relative; z-index: 1; background: linear-gradient(135deg, #fff 0%, rgba(180,210,255,0.8) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .year-desc { font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 8px; position: relative; z-index: 1; }
    .year-arrow { position: absolute; bottom: 22px; font-size: 1.2rem; opacity: 0; transform: translateY(4px); transition: opacity 0.3s, transform 0.3s; z-index: 1; }
    .year-card:hover .year-arrow { opacity: 1; transform: translateY(0); }
    .year-card.inactive { opacity: 0.35; pointer-events: none; }
    .footer-text { font-size: 0.75rem; color: rgba(255,255,255,0.15); letter-spacing: 2px; text-transform: uppercase; }
    @media (max-width: 600px) { .year-card { width: 160px; height: 220px; } .year-number { font-size: 3.2rem; } }
  </style>
</head>
<body>
  <div class="bg"></div>
  <div class="grid-overlay"></div>
  <div class="page">
    <div class="header">
      <p class="label">KUMA · Game & Animation</p>
      <h1>졸업 전시회</h1>
      <p class="sub">연도를 선택해 전시관에 입장하세요</p>
    </div>
    <div class="years-container" id="years-container"></div>
    <p class="footer-text">국민대학교 게임애니메이션과</p>
  </div>

  <script type="module">
    import { getData, isAdmin, injectAdminBar, showEditModal, saveData } from '/js/admin.js';

    let siteData;

    async function init() {
      siteData = await getData();
      render();
      // 관리자로 로그인된 상태면 편집 UI 표시
      if (isAdmin()) {
        injectAdminBar();
        render(); // admin-mode 클래스 붙은 후 재렌더
      }
    }

    function render() {
      const container = document.getElementById('years-container');
      container.innerHTML = '';
      const admin = isAdmin();

      siteData.years.forEach((year, yi) => {
        const card = document.createElement('a');
        card.href = year.active ? `/${year.id}/` : 'javascript:void(0)';
        card.className = `year-card${year.active ? '' : ' inactive'}`;
        card.innerHTML = `
          ${year.thumbnail ? `<div class="year-card-bg" style="background-image:url('${year.thumbnail}')"></div>` : ''}
          <span class="year-badge">${year.active ? 'OPEN' : '준비중'}</span>
          <span class="year-number">${year.label}</span>
          <span class="year-desc">${year.active ? '전시 보러가기' : 'Coming Soon'}</span>
          <span class="year-arrow">→</span>
        `;
        container.appendChild(card);
      });

      // 관리자: 연도 추가 카드
      if (admin) {
        const addCard = document.createElement('div');
        addCard.style.cssText = 'width:100px;height:280px;border-radius:24px;border:2px dashed rgba(255,255,255,0.2);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:rgba(255,255,255,0.3);cursor:pointer;transition:all 0.3s;font-size:0.8rem;';
        addCard.innerHTML = '<span style="font-size:2rem;">+</span><span>연도 추가</span>';
        addCard.onmouseenter = () => { addCard.style.borderColor='rgba(255,255,255,0.5)'; addCard.style.color='rgba(255,255,255,0.6)'; };
        addCard.onmouseleave = () => { addCard.style.borderColor='rgba(255,255,255,0.2)'; addCard.style.color='rgba(255,255,255,0.3)'; };
        addCard.onclick = addYear;
        container.appendChild(addCard);
      }
    }

    function addYear() {
      showEditModal({
        title: '새 연도 추가',
        fields: [
          { key: 'id', label: '연도 ID (예: 2027)', value: '' },
          { key: 'label', label: '표시 텍스트 (예: 2027)', value: '' },
          { key: 'thumbnail', label: '배경 이미지 URL (선택)', value: '' },
        ],
        onSave(v) {
          if (!v.id) return alert('연도 ID를 입력해주세요.');
          siteData.years.push({ id: v.id, label: v.label || v.id, active: true, thumbnail: v.thumbnail, tracks: [] });
          saveData(siteData);
          render();
        }
      });
    }

    init();
  </script>
</body>
</html>
