---
import { fetchSiteData } from '../lib/fetchSheetData';
const { years, info } = await fetchSiteData();
const currentYears = years.filter(y => y.active && y.current);
const pastYears = years.filter(y => y.active && !y.current);
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KUMA 졸업 전시회</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-snap-type: y mandatory; overflow-y: scroll; height: 100%; }
    body { background: #000; color: #fff; font-family: 'Pretendard', 'Inter', sans-serif; height: 100%; }

    /* ── 상단 바 ── */
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: 52px;
      background: rgba(8,8,8,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.07);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 28px;
    }
    .topbar-logos { display: flex; align-items: center; gap: 16px; }
    .topbar-logo { height: 28px; width: auto; object-fit: contain; opacity: 0.85; }
    .topbar-logo-fallback {
      height: 28px; display: flex; align-items: center;
      font-size: 0.78rem; font-weight: 700; color: rgba(255,255,255,0.6);
      letter-spacing: 1px;
    }
    .topbar-divider { width: 1px; height: 20px; background: rgba(255,255,255,0.12); }
    .topbar-links { display: flex; align-items: center; gap: 8px; }
    .topbar-link {
      width: 34px; height: 34px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      text-decoration: none; transition: background 0.2s;
      border: 1px solid rgba(255,255,255,0.1);
    }
    .topbar-link:hover { background: rgba(255,255,255,0.1); }
    .topbar-link svg { width: 16px; height: 16px; fill: rgba(255,255,255,0.7); }

    /* ── 현재 전시 섹션 ── */
    .current-section {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      height: 100vh;
      display: grid;
      grid-template-columns: calc((100vh - 52px) * 1.35) 1fr;
      padding-top: 52px;
      position: relative;
    }

    /* 좌측 메인 비주얼 */
    .main-visual {
      position: relative; overflow: hidden;
      display: flex; flex-direction: column;
      align-items: flex-start; justify-content: flex-start;
      padding: 48px;
      background: #000;
    }
    .main-visual-link {
      text-decoration: none; color: #fff; cursor: pointer;
    }
    .main-hover-overlay {
      position: absolute; inset: 0;
      background: rgba(255,255,255,0);
      transition: background 0.4s; z-index: 1; pointer-events: none;
    }
    .main-visual-link:hover .main-hover-overlay { background: rgba(255,255,255,0.04); }
    .main-bg {
      position: absolute; inset: 0;
      background-size: cover; background-position: center;
      opacity: 0.38;
      transition: transform 0.7s cubic-bezier(0.25,1,0.5,1), opacity 0.4s;
    }
    .main-visual-link:hover .main-bg { opacity: 0.52; transform: scale(1.03); }
    .main-bg-gradient {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(0,40,160,0.65) 0%, rgba(100,0,60,0.45) 100%);
    }
    .main-grid {
      position: absolute; inset: 0;
      background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 50px 50px;
    }
    .main-content {
      position: relative; z-index: 2; width: 100%;
    }
    .main-top { display: flex; flex-direction: column; }
    .main-label { font-size: 0.7rem; letter-spacing: 7px; text-transform: uppercase; color: rgba(255,255,255,0.32); margin-bottom: 14px; display: block; }
    .main-badge { display: inline-block; font-size: 0.58rem; letter-spacing: 3px; text-transform: uppercase; padding: 4px 12px; border-radius: 20px; color: rgba(100,220,255,0.9); background: rgba(0,150,255,0.15); border: 1px solid rgba(0,150,255,0.3); margin-bottom: 16px; align-self: flex-start; }
    .main-title { font-size: clamp(2.2rem, 4vw, 4.5rem); font-weight: 900; letter-spacing: -2px; line-height: 1.05; background: linear-gradient(135deg, #fff 20%, rgba(180,210,255,0.7) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .main-year { font-size: clamp(0.85rem, 1.2vw, 1.1rem); color: rgba(255,255,255,0.3); letter-spacing: 4px; font-weight: 300; margin-top: 10px; }

    /* 입장하기 — 우측 중앙, 화살표만 */
    .main-bottom {
      display: flex; justify-content: flex-end; align-items: center;
      position: absolute; right: 52px; top: 50%; transform: translateY(-50%);
    }
    .main-enter {
      display: flex; align-items: center;
      color: rgba(255,255,255,0.6);
      transition: color 0.3s, transform 0.3s;
    }
    .main-enter-arrow {
      font-size: 4rem; line-height: 1; font-weight: 200;
      transition: transform 0.3s;
    }
    .main-visual-link:hover .main-enter { color: #fff; }
    .main-visual-link:hover .main-enter-arrow { transform: translateX(10px); }

    /* 연도 여러개일 때 카드 */
    .year-cards { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }
    .year-card {
      width: clamp(220px, 25vw, 320px); height: clamp(220px, 25vw, 320px);
      border-radius: 24px; text-decoration: none; color: #fff; overflow: hidden;
      display: flex; flex-direction: column; justify-content: space-between;
      position: relative; padding: 24px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.05); backdrop-filter: blur(10px);
      transition: transform 0.4s cubic-bezier(0.25,1,0.5,1), box-shadow 0.4s, background 0.3s;
    }
    .year-card:hover { transform: translateY(-8px) scale(1.02); background: rgba(255,255,255,0.09); box-shadow: 0 40px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(100,180,255,0.2); }
    .year-card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0.18; }
    .year-badge { display: inline-block; font-size: 0.55rem; letter-spacing: 3px; text-transform: uppercase; padding: 3px 9px; border-radius: 20px; color: rgba(100,220,255,0.9); background: rgba(0,150,255,0.15); border: 1px solid rgba(0,150,255,0.3); margin-bottom: 10px; }
    .card-top { position: relative; z-index: 1; }
    .card-title { font-size: clamp(1.1rem, 2vw, 1.6rem); font-weight: 800; line-height: 1.25; letter-spacing: -0.5px; color: #fff; }
    .card-bottom { position: relative; z-index: 1; display: flex; align-items: flex-end; justify-content: space-between; }
    .year-num { font-size: clamp(2.5rem, 4vw, 4rem); font-weight: 900; letter-spacing: -3px; line-height: 1; background: linear-gradient(135deg, #fff 0%, rgba(180,220,255,0.7) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .card-enter { font-size: 0.68rem; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.35); padding-bottom: 4px; transition: color 0.3s, transform 0.3s; }
    .year-card:hover .card-enter { color: rgba(255,255,255,0.7); transform: translateX(4px); }

    /* 카드 상단 — 제목 */
    .card-top { position: relative; z-index: 1; }
    .year-badge { display: inline-block; font-size: 0.55rem; letter-spacing: 3px; text-transform: uppercase; padding: 3px 9px; border-radius: 20px; color: rgba(100,220,255,0.9); background: rgba(0,150,255,0.15); border: 1px solid rgba(0,150,255,0.3); margin-bottom: 12px; }
    .card-title {
      font-size: clamp(1.3rem, 2.5vw, 1.9rem);
      font-weight: 800; line-height: 1.25; letter-spacing: -0.5px;
      color: #fff; text-align: left;
      text-shadow: 0 2px 20px rgba(0,0,0,0.4);
    }

    /* 카드 하단 — 연도 + 화살표 */
    .card-bottom { position: relative; z-index: 1; display: flex; align-items: flex-end; justify-content: space-between; }
    .year-num {
      font-size: clamp(3rem, 5vw, 5rem); font-weight: 900; letter-spacing: -4px; line-height: 1;
      background: linear-gradient(135deg, #fff 0%, rgba(180,220,255,0.7) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .card-enter {
      font-size: 0.72rem; letter-spacing: 3px; text-transform: uppercase;
      color: rgba(255,255,255,0.35); display: flex; align-items: center; gap: 6px;
      padding-bottom: 6px; transition: color 0.3s, transform 0.3s;
    }
    .year-card:hover .card-enter { color: rgba(255,255,255,0.7); transform: translateX(4px); }

    /* 우측 패널 */
    .side-panel {
      border-left: 1px solid rgba(255,255,255,0.07);
      background: #080808;
      display: flex; flex-direction: column;
      overflow: hidden;
      position: relative;
    }

    /* 전시 개요 */
    .exhibit-info {
      flex: 1;
      padding: 32px 28px 20px;
      display: flex; flex-direction: column; justify-content: center;
      overflow-y: auto;
    }
    .info-tag { font-size: 0.65rem; letter-spacing: 5px; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 16px; display: block; font-weight: 600; }
    .exhibit-title { font-size: 1.3rem; font-weight: 800; color: #fff; margin-bottom: 16px; line-height: 1.3; letter-spacing: -0.5px; }
    .info-row { display: flex; gap: 10px; margin-bottom: 10px; align-items: flex-start; }
    .info-icon { font-size: 0.82rem; margin-top: 1px; flex-shrink: 0; opacity: 0.6; }
    .info-text { font-size: 0.82rem; color: rgba(255,255,255,0.65); line-height: 1.6; font-weight: 400; }
    .exhibit-desc { font-size: 0.8rem; color: rgba(255,255,255,0.45); line-height: 1.8; margin-top: 14px; padding-top: 14px; border-top: 1px solid rgba(255,255,255,0.06); word-break: keep-all; }

    /* 지도 — 가로로 넓은 비율, 중앙 배치 */
    .map-section {
      position: relative;
      background: #080808;
      flex-shrink: 0;
      padding: 0 16px 16px 16px;
      width: 80%;
      aspect-ratio: 4 / 3;
      align-self: center;
    }
    .map-section iframe { width: 100%; height: 100%; border: none; display: block; border-radius: 16px; filter: invert(1) hue-rotate(180deg) saturate(0.4) brightness(0.85); }
    .map-placeholder {
      width: 100%; height: 100%;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 8px; color: rgba(255,255,255,0.2); font-size: 0.8rem; border-radius: 16px;
      border: 1px dashed rgba(255,255,255,0.08);
    }
    .map-placeholder svg { opacity: 0.3; }
    .map-overlay {
      position: absolute; inset: 0;
      display: flex; align-items: flex-end;
      padding: 0 20px 34px 20px;
      pointer-events: none;
    }
    .map-link {
      font-size: 0.7rem; color: rgba(255,255,255,0.55); text-decoration: none;
      letter-spacing: 2px; text-transform: uppercase; font-weight: 500;
      display: flex; align-items: center; gap: 6px; transition: color 0.2s;
      pointer-events: all;
      background: rgba(0,0,0,0.4); padding: 6px 12px; border-radius: 20px;
      backdrop-filter: blur(4px);
    }
    .map-link:hover { color: #fff; }

    /* 스크롤 힌트 */
    .scroll-hint {
      position: absolute; bottom: 28px; left: 50%;
      transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      color: rgba(255,255,255,0.2); font-size: 0.65rem; letter-spacing: 2px; text-transform: uppercase;
      animation: bounce 2.5s infinite; pointer-events: none; z-index: 10;
    }
    @keyframes bounce { 0%,100% { transform: translateX(-50%) translateY(0); } 60% { transform: translateX(-50%) translateY(8px); } }

    /* ── 과거 전시 섹션 ── */
    .past-section {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      height: 100vh;
      padding: 80px 60px 60px;
      background: #050505;
      display: flex; flex-direction: column; align-items: flex-start; justify-content: center;
      gap: 40px;
    }
    .past-header { text-align: left; }
    .past-tag { font-size: 0.68rem; letter-spacing: 6px; text-transform: uppercase; color: rgba(255,255,255,0.2); display: block; margin-bottom: 8px; }
    .past-heading { font-size: 2.2rem; font-weight: 700; color: rgba(255,255,255,0.5); }
    .past-line { width: 40px; height: 1px; background: rgba(255,255,255,0.1); margin-top: 14px; }

    /* 가로 스크롤 */
    .past-cards {
      display: flex; gap: 24px;
      overflow-x: auto; overflow-y: visible;
      width: 100%; padding-bottom: 16px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .past-cards::-webkit-scrollbar { display: none; }

    .past-card {
      flex-shrink: 0;
      width: 420px; height: 420px;
      border-radius: 28px;
      text-decoration: none; color: #fff; overflow: hidden;
      display: flex; flex-direction: column; justify-content: space-between;
      position: relative; padding: 32px;
      border: 1px solid rgba(255,255,255,0.08);
      background: #0d0d0d;
      opacity: 0.65;
      transition: transform 0.35s cubic-bezier(0.25,1,0.5,1), opacity 0.3s, box-shadow 0.35s;
      scroll-snap-align: start;
    }
    .past-card:hover { transform: translateY(-8px) scale(1.01); opacity: 1; box-shadow: 0 30px 70px rgba(0,0,0,0.6); border-color: rgba(255,255,255,0.15); }
    .past-card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0.15; transition: opacity 0.3s; }
    .past-card:hover .past-card-bg { opacity: 0.25; }

    .past-card-top { position: relative; z-index: 1; }
    .past-num { font-size: 5rem; font-weight: 900; letter-spacing: -5px; line-height: 1; color: rgba(255,255,255,0.8); display: block; }
    .past-card-bottom { position: relative; z-index: 1; display: flex; justify-content: flex-end; align-items: flex-end; }
    .past-go {
      display: flex; flex-direction: column; align-items: flex-end; gap: 4px;
      color: rgba(255,255,255,0.35);
      transition: color 0.3s, transform 0.3s;
    }
    .past-go-text { font-size: 0.75rem; letter-spacing: 3px; text-transform: uppercase; font-weight: 500; }
    .past-go-arrow { font-size: 2rem; line-height: 1; font-weight: 200; }
    .past-card:hover .past-go { color: rgba(255,255,255,0.8); transform: translate(4px, -4px); }

    .footer-text { font-size: 0.68rem; color: rgba(255,255,255,0.1); letter-spacing: 3px; text-transform: uppercase; }

    /* ── 모바일 전용 (PC에서 숨김) ── */
    .m-scroll-container { display: none; }

    .m-scroll-container {
      position: fixed;
      top: 48px; left: 0; right: 0;
      height: calc(100vh - 48px);
      overflow-y: scroll;
      scroll-snap-type: y mandatory;
      -webkit-overflow-scrolling: touch;
      z-index: 50;
    }

    .m-slide {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      height: calc(100vh - 48px);
      position: relative;
      overflow: hidden;
      flex-shrink: 0;
    }

    /* 슬라이드1: 메인 비주얼 */
    .m-slide-visual { display: flex; flex-direction: column; }
    .m-visual-link { display: flex; flex-direction: column; align-items: flex-start; justify-content: flex-start; width: 100%; height: 100%; text-decoration: none; color: #fff; padding: 28px; position: relative; }
    .m-bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0.4; }
    .m-bg-gradient { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(0,40,160,0.65) 0%, rgba(100,0,60,0.45) 100%); }
    .m-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px); background-size: 44px 44px; }
    .m-content { position: relative; z-index: 2; width: 100%; }
    .m-label { font-size: 0.62rem; letter-spacing: 6px; text-transform: uppercase; color: rgba(255,255,255,0.32); margin-bottom: 10px; display: block; }
    .m-badge { display: inline-block; font-size: 0.5rem; letter-spacing: 3px; text-transform: uppercase; padding: 3px 8px; border-radius: 20px; color: rgba(100,220,255,0.9); background: rgba(0,150,255,0.15); border: 1px solid rgba(0,150,255,0.3); margin-bottom: 10px; }
    .m-title { font-size: clamp(1.8rem, 6vw, 2.8rem); font-weight: 900; letter-spacing: -1.5px; line-height: 1.05; background: linear-gradient(135deg, #fff 20%, rgba(180,210,255,0.7) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .m-year { font-size: 0.82rem; color: rgba(255,255,255,0.3); letter-spacing: 4px; font-weight: 300; margin-top: 8px; }
    .m-arrow { position: absolute; right: 28px; top: 50%; transform: translateY(-50%); font-size: 2.8rem; color: rgba(255,255,255,0.5); font-weight: 200; z-index: 2; }
    .m-scroll-hint { position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 6px; color: rgba(255,255,255,0.25); font-size: 0.6rem; letter-spacing: 2px; text-transform: uppercase; animation: bounce 2.5s infinite; z-index: 10; pointer-events: none; }

    /* 슬라이드2: 전시개요 — 메인비주얼 배경 복사 */
    .m-slide-info { display: flex; flex-direction: column; background: #000; }
    .m-info-bg-fixed { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0.25; filter: blur(6px); transform: scale(1.05); }
    .m-info-bg-dim { position: absolute; inset: 0; background: rgba(0,0,0,0.62); }
    .m-info-inner { position: relative; z-index: 2; display: flex; flex-direction: column; height: 100%; }
    .m-info-handle { width: 40px; height: 4px; border-radius: 2px; background: rgba(255,255,255,0.2); margin: 14px auto 0; flex-shrink: 0; }
    .m-exhibit { flex: 1; padding: 20px 24px 16px; display: flex; flex-direction: column; justify-content: center; border-bottom: 1px solid rgba(255,255,255,0.07); overflow-y: auto; min-height: 0; }
    .m-info-tag { font-size: 0.62rem; letter-spacing: 5px; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 12px; display: block; font-weight: 600; }
    .m-exhibit-title { font-size: 1.2rem; font-weight: 800; color: #fff; margin-bottom: 14px; line-height: 1.3; letter-spacing: -0.5px; }
    .m-info-row { display: flex; gap: 10px; margin-bottom: 8px; align-items: flex-start; }
    .m-info-icon { font-size: 0.8rem; flex-shrink: 0; opacity: 0.6; margin-top: 1px; }
    .m-info-text { font-size: 0.82rem; color: rgba(255,255,255,0.65); line-height: 1.6; }
    .m-exhibit-desc { font-size: 0.78rem; color: rgba(255,255,255,0.4); line-height: 1.75; margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.06); word-break: keep-all; }
    .m-map { flex: 1; position: relative; padding: 14px 20px 20px; min-height: 0; }
    .m-map iframe { width: 100%; height: 100%; border: none; border-radius: 16px; display: block; filter: invert(1) hue-rotate(180deg) saturate(0.4) brightness(0.85); }
    .m-map-placeholder { width: 100%; height: 100%; border-radius: 16px; display: flex; align-items: center; justify-content: center; border: 1px dashed rgba(255,255,255,0.1); color: rgba(255,255,255,0.2); font-size: 0.78rem; flex-direction: column; gap: 8px; }
    .m-map-link { position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%); font-size: 0.65rem; color: rgba(255,255,255,0.5); text-decoration: none; letter-spacing: 2px; text-transform: uppercase; background: rgba(0,0,0,0.5); padding: 5px 12px; border-radius: 20px; backdrop-filter: blur(4px); white-space: nowrap; }

    /* 슬라이드3: 과거 전시 */
    .m-slide-past {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      height: auto; min-height: calc(100vh - 48px);
      background: #050505;
      display: flex; flex-direction: column;
      padding: 52px 20px 40px; gap: 28px;
      overflow-y: auto; flex-shrink: 0;
    }
    .m-past-tag { font-size: 0.68rem; letter-spacing: 6px; text-transform: uppercase; color: rgba(255,255,255,0.2); display: block; margin-bottom: 8px; }
    .m-past-heading { font-size: 1.6rem; font-weight: 700; color: rgba(255,255,255,0.5); }
    .m-past-cards-wrap { display: flex; gap: 16px; overflow-x: auto; padding-bottom: 8px; scrollbar-width: none; }
    .m-past-cards-wrap::-webkit-scrollbar { display: none; }
    .m-past-card { flex-shrink: 0; width: 68vw; height: 68vw; border-radius: 20px; text-decoration: none; color: #fff; overflow: hidden; display: flex; flex-direction: column; justify-content: space-between; position: relative; padding: 22px; border: 1px solid rgba(255,255,255,0.08); background: #0d0d0d; opacity: 0.75; }
    .m-past-card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: 0.15; }
    .m-past-num { font-size: 4rem; font-weight: 900; letter-spacing: -4px; color: rgba(255,255,255,0.8); position: relative; z-index: 1; }
    .m-past-go { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; position: relative; z-index: 1; color: rgba(255,255,255,0.35); }
    .m-past-go-text { font-size: 0.65rem; letter-spacing: 3px; text-transform: uppercase; }
    .m-past-go-arrow { font-size: 1.8rem; line-height: 1; font-weight: 200; }

    /* ── 모바일 미디어 쿼리 ── */
    @media (max-width: 768px) {
      html, body { height: 100%; overflow: hidden; }
      .topbar { padding: 0 16px; height: 48px; }
      .topbar-logo-fallback { font-size: 0.68rem; }
      .topbar-link { width: 30px; height: 30px; }
      .topbar-link svg { width: 13px; height: 13px; }
      .current-section { display: none !important; }
      .scroll-hint { display: none !important; }
      .past-section { display: none !important; }
      .m-scroll-container { display: block !important; }
    }  </style>
</head>
<body>

  <!-- 상단 바 -->
  <header class="topbar">
    <div class="topbar-logos">
      {info.schoolLogoUrl
        ? <img src={info.schoolLogoUrl} alt="학교 로고" class="topbar-logo" />
        : <span class="topbar-logo-fallback">한국영상대학교</span>
      }
      {(info.schoolLogoUrl && info.deptLogoUrl) && <div class="topbar-divider"></div>}
      {info.deptLogoUrl
        ? <img src={info.deptLogoUrl} alt="학과 로고" class="topbar-logo" />
        : <span class="topbar-logo-fallback" style="opacity:0.5">게임애니메이션과</span>
      }
    </div>

    <div class="topbar-links">
      {info.schoolUrl && (
        <a href={info.schoolUrl} target="_blank" rel="noopener" class="topbar-link" title="학교 홈페이지">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
        </a>
      )}
      {info.youtubeUrl && (
        <a href={info.youtubeUrl} target="_blank" rel="noopener" class="topbar-link" title="유튜브">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      )}
      {info.instagramUrl && (
        <a href={info.instagramUrl} target="_blank" rel="noopener" class="topbar-link" title="인스타그램">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
      )}
    </div>
  </header>

  <!-- 모바일 전용: 스크롤 스냅 컨테이너 -->
  <div class="m-scroll-container" id="m-scroll-container">

    <!-- 슬라이드 1: 메인 비주얼 -->
    <div class="m-slide m-slide-visual">
      {currentYears.length >= 1 ? (
        <a href={`/${currentYears[0].id}/`} class="m-visual-link">
          {(info.bgImage || currentYears[0].thumbnail) &&
            <div class="m-bg" style={`background-image:url('${info.bgImage || currentYears[0].thumbnail}')`}></div>
          }
          <div class="m-bg-gradient"></div>
          <div class="m-grid"></div>
          <div class="m-content">
            <span class="m-label">KUMA · Game & Animation</span>
            <span class="m-badge">NOW</span>
            <h1 class="m-title">{info.exhibitionTitle || '졸업 전시회'}</h1>
            <p class="m-year">{currentYears[0].label}</p>
          </div>
          <span class="m-arrow">→</span>
        </a>
      ) : null}
      <div class="m-scroll-hint">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M8 3v10M3 9l5 5 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>전시 정보</span>
      </div>
    </div>

    <!-- 슬라이드 2: 전시 개요 (메인비주얼 배경 복사) -->
    <div class="m-slide m-slide-info">
      {(info.bgImage || (currentYears[0] && currentYears[0].thumbnail)) &&
        <div class="m-info-bg-fixed" style={`background-image:url('${info.bgImage || currentYears[0]?.thumbnail}')`}></div>
      }
      <div class="m-info-bg-dim"></div>
      <div class="m-info-inner">
        <div class="m-info-handle"></div>
        <div class="m-exhibit">
          <span class="m-info-tag">Exhibition Info</span>
          <h2 class="m-exhibit-title">{info.exhibitionTitle || '졸업 전시회'}</h2>
          {info.exhibitionDate && (
            <div class="m-info-row">
              <span class="m-info-icon">📅</span>
              <span class="m-info-text">{info.exhibitionDate}</span>
            </div>
          )}
          {info.exhibitionPlace && (
            <div class="m-info-row">
              <span class="m-info-icon">📍</span>
              <span class="m-info-text">{info.exhibitionPlace}</span>
            </div>
          )}
          {info.exhibitionDesc && (
            <p class="m-exhibit-desc">{info.exhibitionDesc}</p>
          )}
        </div>
        <div class="m-map">
          {info.mapUrl
            ? <iframe src={`${info.mapUrl}&iwloc=&`} width="100%" height="100%" style="border:0;pointer-events:none;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            : <div class="m-map-placeholder">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="white" opacity="0.3"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
                <span>지도 준비 중</span>
              </div>
          }
          {info.mapLinkUrl && <a href={info.mapLinkUrl} target="_blank" class="m-map-link">지도에서 보기 →</a>}
        </div>
      </div>
    </div>

    <!-- 슬라이드 3: 과거 전시 -->
    {pastYears.length > 0 && (
      <div class="m-slide-past">
        <div>
          <span class="m-past-tag">Archive</span>
          <p class="m-past-heading">과거 전시</p>
        </div>
        <div class="m-past-cards-wrap">
          {pastYears.map(year => (
            <a href={`/${year.id}/`} class="m-past-card">
              {year.thumbnail && <div class="m-past-card-bg" style={`background-image:url('${year.thumbnail}')`}></div>}
              <span class="m-past-num">{year.label}</span>
              <div class="m-past-go">
                <span class="m-past-go-text">보러가기</span>
                <span class="m-past-go-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
        <p style="font-size:0.65rem;color:rgba(255,255,255,0.1);letter-spacing:3px;text-transform:uppercase;text-align:center;">한국영상대학교 게임애니메이션과</p>
      </div>
    )}

  </div>

  <!-- 현재 전시 섹션 (PC) -->
  <section class="current-section">

    <!-- 좌측 메인 비주얼 — 전체가 버튼 (연도 1개 기준) -->
    {currentYears.length === 1 ? (
      <a href={`/${currentYears[0].id}/`} class="main-visual main-visual-link">
        {info.bgImage
          ? <div class="main-bg" style={`background-image:url('${info.bgImage}')`}></div>
          : currentYears[0].thumbnail
            ? <div class="main-bg" style={`background-image:url('${currentYears[0].thumbnail}')`}></div>
            : null
        }
        <div class="main-bg-gradient"></div>
        <div class="main-grid"></div>
        <div class="main-hover-overlay"></div>

        <div class="main-content">
          <div class="main-top">
            <span class="main-label">KUMA · Game & Animation</span>
            <span class="main-badge">NOW</span>
            <h1 class="main-title">{info.exhibitionTitle || '졸업 전시회'}</h1>
            <p class="main-year">{currentYears[0].label}</p>
          </div>
        </div>
        <div class="main-bottom">
          <div class="main-enter">
            <span class="main-enter-arrow">→</span>
          </div>
        </div>
      </a>
    ) : (
      <div class="main-visual">
        {info.bgImage && <div class="main-bg" style={`background-image:url('${info.bgImage}')`}></div>}
        <div class="main-bg-gradient"></div>
        <div class="main-grid"></div>

        <div class="main-content">
          <span class="main-label">KUMA · Game & Animation</span>
          <div class="year-cards">
            {currentYears.map(year => (
              <a href={`/${year.id}/`} class="year-card">
                {year.thumbnail && <div class="year-card-bg" style={`background-image:url('${year.thumbnail}')`}></div>}
                <div class="card-top">
                  <span class="year-badge">NOW</span>
                  <p class="card-title">{info.exhibitionTitle || '졸업 전시회'}</p>
                </div>
                <div class="card-bottom">
                  <span class="year-num">{year.label}</span>
                  <span class="card-enter">입장하기 →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- 우측 패널 -->
    <div class="side-panel">
      <!-- 전시 개요 -->
      <div class="exhibit-info">
        <span class="info-tag">Exhibition Info</span>
        <h2 class="exhibit-title">{info.exhibitionTitle || '졸업 전시회'}</h2>

        {info.exhibitionDate && (
          <div class="info-row">
            <span class="info-icon">📅</span>
            <span class="info-text">{info.exhibitionDate}</span>
          </div>
        )}
        {info.exhibitionPlace && (
          <div class="info-row">
            <span class="info-icon">📍</span>
            <span class="info-text">{info.exhibitionPlace}</span>
          </div>
        )}
        {info.exhibitionDesc && (
          <p class="exhibit-desc">{info.exhibitionDesc}</p>
        )}
      </div>

      <!-- 지도 -->
      <div class="map-section">
        {info.mapUrl
          ? <iframe
              src={`${info.mapUrl}&iwloc=&`}
              width="100%"
              height="100%"
              style="border:0;pointer-events:none;"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          : (
            <div class="map-placeholder">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="white"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <span>지도 embed URL을 시트에 입력해주세요</span>
            </div>
          )
        }
        <div class="map-overlay">
          {info.mapLinkUrl && (
            <a href={info.mapLinkUrl} target="_blank" rel="noopener" class="map-link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              지도에서 보기
            </a>
          )}
        </div>
      </div>
    </div>

    {pastYears.length > 0 && (
      <div class="scroll-hint">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M8 3v10M3 9l5 5 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>과거 전시</span>
      </div>
    )}
  </section>

  <!-- 과거 전시 섹션 -->
  {pastYears.length > 0 && (
    <section class="past-section">
      <div class="past-header">
        <span class="past-tag">Archive</span>
        <p class="past-heading">과거 전시</p>
        <div class="past-line"></div>
      </div>

      <div class="past-cards">
        {pastYears.map(year => (
          <a href={`/${year.id}/`} class="past-card">
            {year.thumbnail && <div class="past-card-bg" style={`background-image:url('${year.thumbnail}')`}></div>}
            <div class="past-card-top">
              <span class="past-num">{year.label}</span>
            </div>
            <div class="past-card-bottom">
              <div class="past-go">
                <span class="past-go-text">보러가기</span>
                <span class="past-go-arrow">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <p class="footer-text">한국영상대학교 게임애니메이션과</p>
    </section>
  )}

  {pastYears.length === 0 && (
    <div style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);font-size:0.68rem;color:rgba(255,255,255,0.1);letter-spacing:3px;text-transform:uppercase;">
      한국영상대학교 게임애니메이션과
    </div>
  )}


</body>
</html>
