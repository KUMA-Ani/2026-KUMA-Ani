---
import projects from '../../data/projects.json';
const { id } = Astro.params;

export function getStaticPaths() {
  return projects.filter(p => p.id && p.track).map(p => ({
    params: { id: p.id }
  }));
}

const project = projects.find(p => p.id === id);
const sampleImg = "/2026-KUMA-Ani/images/sample.jpg";
---

<html lang="ko">
<head>
    <meta charset="utf-8" />
    <title>{project?.title} - Showcase</title>
    <style>
        body { background: #000; color: #eee; font-family: 'Pretendard', sans-serif; margin: 0; padding: 0; }
        .container { max-width: 1400px; margin: 0 auto; padding: 60px 20px; }
        .back-btn { color: #888; text-decoration: none; display: block; margin-bottom: 20px; font-size: 2rem; }
        
        .page-header { margin-bottom: 50px; }
        .page-header h1 { font-size: 2.8rem; margin: 0; font-weight: 800; }
        .page-header .subtitle { color: #666; font-size: 1.1rem; margin-top: 10px; }

        .content-layout { 
            display: grid; 
            grid-template-columns: 1fr .1fr; 
            gap: 15px; 
            align-items: start;
            margin-bottom: 60px; 
        }

        /* --- 좌측 컬럼: 영상 & 다운로드 --- */
        .left-col .video-box iframe { 
            width: 100%; aspect-ratio: 16/9; border-radius: 12px; border: 1px solid #222; 
        }
        .download-btn { 
            display: block; width: 100%; box-sizing: border-box;
            padding: 37px; background: #007bff; color: white; text-align: center; 
            text-decoration: none; border-radius: 12px; font-weight: bold; font-size: 1.1rem;
            margin-top: 25px; transition: 0.3s;
        }
        .download-btn:hover { background: #0069d9; transform: translateY(-2px); }

        /* --- 우측 컬럼: 큰 카드 설정 --- */
        .info-card { 
            background: #111; border: 1px solid #222; border-radius: 20px; 
            box-sizing: border-box;
        }

        .description-card {
            padding: 40px;
            min-height: 300px;
            margin-bottom: 15px;
        }

        .members-card {
            padding: 35px;
            min-height: 285px;
        }
        
        .info-card h2 { 
            font-size: 1.4rem; margin: 0 0 20px 0; display: flex; align-items: center; 
            font-weight: 700; color: #fff;
        }
        .info-card h2::before { 
            content: ''; display: inline-block; width: 4px; height: 1.2rem; 
            background: #007bff; margin-right: 12px; border-radius: 2px;
        }

        .description { line-height: 1.8; color: #ccc; font-size: 1rem; word-break: keep-all; }

        /* --- 💡 제작진 이름 박스 세부 설정 영역 --- */
        .members-grid { 
            display: grid; 
            /* 1. 가로 배치 설정: 1fr 1fr은 5:5 비율로 두 칸 배치입니다. 
               한 줄에 한 명만 꽉 채우고 싶다면 1fr로 수정하세요. */
            grid-template-columns: 100px 100px 100px 100px 100px; 
            gap: 5px; 
        }

        .member-item { 
            background: #1a1a1a; 
            border: 1px solid #4a4a4a; 
            border-radius: 10px; 
            
            /* 2. 세로 크기 설정: 이 값을 조절하여 박스의 높이를 바꿉니다. */
            min-height: 1px; 
            
            /* 3. 내부 여백 설정 */
            padding: 10px; 

            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }
        
        .member-role { font-size: 1rem; color: #b8b8b8; margin-bottom: -5px; font-weight: 1000; display: block; }
        .member-name { font-size: 1.5rem; color: #fff; font-weight: 700; display: block; }

        /* --- 하단 이미지 --- */
        .gallery { border-top: 1px solid #222; padding-top: 60px; }
        .screenshot-list { display: flex; flex-direction: column; gap: 40px; }
        .screenshot-list img { width: 100%; border-radius: 15px; border: 1px solid #111; }

        @media (max-width: 1024px) {
            .content-layout { grid-template-columns: 1fr; }
            .members-grid { grid-template-columns: 1fr; } /* 모바일에선 한 줄 배치 */
        }
    </style>
</head>
<body>
    <div class="container">
        <a href={`/2026-KUMA-Ani/track/${project?.track}/`} class="back-btn">⬅ 목록으로 돌아가기</a>
        
        <div class="page-header">
            <h1>{project?.title}</h1>
            <p class="subtitle">{project?.team} | {project?.type === 'team' ? 'TEAM PROJECT' : 'INDIVIDUAL'}</p>
        </div>
        
        <div class="content-layout">
            <div class="left-col">
                <div class="video-box">
                    <iframe src={`https://www.youtube.com/embed/${project?.youtubeId}`} frameborder="0" allowfullscreen></iframe>
                </div>
                {project?.track === 'Games' && (
                    <a href="#" class="download-btn"> 게임 다운로드하기! </a>
                )}
            </div>

            <div class="right-col">
                <div class="info-card description-card">
                    <h2>작품 개요</h2>
                    <div class="description">{project?.description}</div>
                </div>

                <div class="info-card members-card">
                    <h2>제작진</h2>
                    <div class="members-grid">
                        {project?.members?.map(m => (
                            <div class="member-item">
                                <span class="member-role">{m.role}</span>
                                <span class="member-name">{m.name}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>

        <div class="gallery">
            <div class="screenshot-list">
                {[...Array(10)].map((_) => (
                    <img src={sampleImg} alt="Showcase Image" loading="lazy" />
                ))}
            </div>
        </div>
    </div>
</body>
</html>