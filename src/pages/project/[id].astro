---
import projects from '../../data/projects.json';
const { id } = Astro.params;

export function getStaticPaths() {
  return projects.filter(p => p.id && p.track).map(p => ({
    params: { id: p.id }
  }));
}

const project = projects.find(p => p.id === id);
/* 수정: 이미지 경로에서 /2026-KUMA-Ani/ 제거 */
const sampleImg = "/images/sample.jpg";
---

<html lang="ko">
<head>
    <meta charset="utf-8" />
    <title>{project?.title} - Showcase</title>
    <style>
        /* (기존 스타일 코드와 동일하여 생략합니다) */
    </style>
</head>
<body>
    <div class="container">
        /* 수정: /2026-KUMA-Ani/ 제거 */
        <a href={`/track/${project?.track}/`} class="back-btn">⬅ 목록으로 돌아가기</a>
        
        <div class="page-header">
            <h1>{project?.title}</h1>
            <p class="subtitle">{project?.team} | {project?.type === 'team' ? 'TEAM PROJECT' : 'INDIVIDUAL'}</p>
        </div>
        
        </div>
</body>
</html>
